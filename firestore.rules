rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'administrador';
    }

    function isCallParticipant(callId) {
      return request.auth != null
        && (request.auth.uid == get(/databases/$(database)/documents/calls/$(callId)).data.callerId
            || request.auth.uid == get(/databases/$(database)/documents/calls/$(callId)).data.calleeId);
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (
        isAdmin()
        || (request.auth.uid == userId
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'name',
              'email',
              'emailLower',
              'userTag',
              'userTagLower',
              'photoURL',
              'photoData',
              'friends',
              'blocked',
              'fcmTokens',
              'friendAliases',
              'showOnlineStatus',
              'online',
              'lastSeen',
              'updatedAt',
              'activity'
            ]))
      );
    }

    match /conversations/{conversationId} {
      allow read, write: if request.auth != null;
    }

    match /conversations/{conversationId}/messages/{messageId} {
      allow read, create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null
        && (resource.data.senderId == request.auth.uid
            || resource.data.receiverId == request.auth.uid);
    }

    match /calls/{callId} {
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.callerId;
      allow read, update, delete: if request.auth != null
        && (request.auth.uid == resource.data.callerId
            || request.auth.uid == resource.data.calleeId);

      match /callerCandidates/{candidateId} {
        allow read, write: if isCallParticipant(callId);
      }

      match /calleeCandidates/{candidateId} {
        allow read, write: if isCallParticipant(callId);
      }
    }
  }
}
